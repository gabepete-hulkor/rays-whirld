          <tr><td>Small</td><td>2 ft. – 4 ft.</td><td>+1 Size, +1 Fly, -1 Special</td></tr>
          <tr><td>Tiny</td><td>1 ft. – 2 ft.</td><td>+2 Size, +2 Fly, -2 Special</td></tr>
        </tbody>
      </table>

